# Copy to .env and fill in only the keys you want to use locally.
# .env is ignored via .gitignore.

# Anthropic / Claude
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY-HERE

# OpenAI / GPT (optional)
# OPENAI_API_KEY=YOUR-OPENAI-KEY-HERE

# Model defaults
LLM_DEFAULT_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=2048

# Optional output override. Defaults to repo-local data/llm
# THINGS_AI_OUTPUT_DIR=./data/llm

# Compatibility with the existing orca pattern if you want one shared variable name.
# SKILLS_OUTPUT_DIR=./data/llm